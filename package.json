{
  "name": "lastfm-app",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild public/src/main.js --bundle --outfile=public/app.js --minify --platform=browser",
    "dev": "esbuild public/src/main.js --bundle --outfile=public/app.js --platform=browser --watch",
    "test": "node --test tests/*.test.js",
    "test:watch": "node --test --watch tests/*.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "http-proxy-middleware": "^3.0.5",
    "pino": "^10.3.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2"
  }
}

# Last.fm instellingen
# Haal je API-sleutel op via: https://www.last.fm/api/account/create
LASTFM_API_KEY=jouw_lastfm_api_sleutel
LASTFM_USER=jouw_lastfm_gebruikersnaam

# Plex instellingen (optioneel)
# Haal je Plex-token op via: https://support.plex.tv/articles/204059436
PLEX_URL=http://host.docker.internal:32400
PLEX_TOKEN=jouw_plex_token
# Plex music library ID (zodat Tidarr bij voltooiing de juiste library kan refreshen)
PLEX_LIBRARY_ID=1

# AudioMuse-AI instellingen
# Media server type: plex, jellyfin, emby, subsonic, navidrome
MEDIASERVER_TYPE=plex
# PostgreSQL wachtwoord (gebruik een sterk wachtwoord in productie)
POSTGRES_PASSWORD=changeme
# AudioMuse web interface inloggegevens
AUDIOMUSE_USER=admin
AUDIOMUSE_PASSWORD=changeme

# Tidarr instellingen (optioneel)
# Tidarr (https://github.com/cstaelen/tidarr) draait als eigen container op poort 8484.
TIDARR_URL=http://tidarr:8484
TIDARR_API_KEY=jouw_tidarr_api_sleutel

# Tiddl auth - fix voor Tidal API wijziging (april 2026)
# Vereist als downloads op "high"/"max" kwaliteit falen met "is not a valid FLAC file"
# Zie: https://github.com/cstaelen/tidarr/issues/749
# Waarde: <client_id>;<client_secret>  (vraag op via Tidal developer portal)
TIDDL_AUTH=

# Spotify instellingen (optioneel)
# Maak een app aan via: https://developer.spotify.com/dashboard
# Gebruik de Client ID en Client Secret van jouw Spotify app.
# Als deze ontbreken, is de mood-toolbar verborgen en worden er geen Spotify-aanbevelingen getoond.
SPOTIFY_CLIENT_ID=jouw_spotify_client_id
SPOTIFY_CLIENT_SECRET=jouw_spotify_client_secret

# MediaSage AI Provider (kies er één)
# Google Gemini (gratis tier beschikbaar): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Anthropic Claude (optioneel): https://console.anthropic.com
# ANTHROPIC_API_KEY=
# OpenAI (optioneel): https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Logging (optioneel)
# Beschikbare levels: trace, debug, info, warn, error, fatal (default: info)
# In productie (Docker) worden logs als JSON uitgestoomd — gebruik 'debug' voor meer details.
LOG_LEVEL=info
